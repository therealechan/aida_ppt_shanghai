# Files that should NOT be served as Workers static assets.
# (Workers Static Assets ignores patterns here, similar to .gitignore.)

# Build & deps
node_modules
package.json
package-lock.json
bun.lock
bun.lockb

# Worker source (loaded as the worker script, not as static assets)
worker.js
functions
.assetsignore

# Wrangler & CF local state
wrangler.jsonc
wrangler.toml
.wrangler
.dev.vars*
.env*

# Git / repo metadata
.git
.github
.gitattributes
.gitignore

# Docs (don't leak repo internals to the public site)
AGENT.md
SKILL.md
README.md

# OS noise
.DS_Store
Thumbs.db
